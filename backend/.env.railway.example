# Railway Environment Configuration
# Copy these to Railway dashboard under "Variables" tab

# Application
NODE_ENV=production
PORT=3001

# Database (Railway PostgreSQL)
# Railway automatically provides this as ${{Postgres.DATABASE_URL}}
DATABASE_URL=${{Postgres.DATABASE_URL}}

# Redis (Railway Redis)
# Railway automatically provides this as ${{Redis.REDIS_URL}}
REDIS_URL=${{Redis.REDIS_URL}}

# Security Configuration
# Generate secure secrets using: openssl rand -base64 32
JWT_SECRET=your-super-secure-jwt-secret-minimum-32-characters-long
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Discord OAuth Configuration
# Get these from https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=https://yourdomain.com/auth/callback

# CORS Configuration
# Set to your Vercel frontend domain
CORS_ORIGIN=https://yourdomain.vercel.app

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Optional: Sentry for error tracking
# SENTRY_DSN=your-sentry-dsn-here

# Railway-specific optimizations
# These are automatically set by Railway but can be overridden
# RAILWAY_ENVIRONMENT=production
# RAILWAY_SERVICE_NAME=mattyspins-api