# ============================================
# DISCORD CONFIGURATION (REQUIRED)
# ============================================
# Get these from: https://discord.com/developers/applications

# Discord Application ID (Client ID)
# Where: Discord Developer Portal → Your App → General Information → Application ID
DISCORD_CLIENT_ID="your-discord-client-id"

# Discord Client Secret
# Where: Discord Developer Portal → Your App → OAuth2 → General → Client Secret
DISCORD_CLIENT_SECRET="your-discord-client-secret"

# Discord OAuth Redirect URI
# For local development, use this:
DISCORD_REDIRECT_URI="http://localhost:3001/api/auth/discord/callback"
# For production, change to:
# DISCORD_REDIRECT_URI="https://your-backend-domain.com/api/auth/discord/callback"
# IMPORTANT: Must also add this URL in Discord Developer Portal → OAuth2 → Redirects

# ============================================
# DISCORD SERVER CONFIGURATION (REQUIRED)
# ============================================

# Require users to be members of your Discord server?
# Set to "true" to require membership, "false" to allow anyone
DISCORD_REQUIRE_SERVER_MEMBERSHIP="true"

# Discord Server ID (Guild ID)
# How to get: Enable Developer Mode → Right-click server icon → Copy Server ID
DISCORD_GUILD_ID="your-discord-server-id"

# Discord Server Invite Link
# How to create: Right-click channel → Invite People → Set to never expire → Copy link
DISCORD_INVITE_URL="https://discord.gg/your-invite-code"

# ============================================
# ADMIN CONFIGURATION (REQUIRED)
# ============================================

# Discord User ID(s) of admin(s)
# How to get: Enable Developer Mode → Right-click username → Copy User ID
# Multiple admins: Separate with commas (no spaces)
# Example: "123456789012345678,987654321098765432"
ADMIN_DISCORD_IDS="your-discord-user-id"

# ============================================
# KICK OAUTH CONFIGURATION (REQUIRED)
# ============================================

# Kick API Base URL (don't change unless Kick changes their API)
KICK_API_BASE_URL="https://kick.com/api/v2"

# Kick OAuth Base URL (don't change unless Kick changes their OAuth)
KICK_OAUTH_BASE_URL="https://kick.com/oauth2"

# Kick Channel Username (NOT the full URL, just the username)
# Example: If channel is kick.com/streamername, use "streamername"
KICK_CHANNEL_NAME="your-kick-username"

# Kick OAuth Client ID
# Get these from: https://kick.com/developer/applications
KICK_CLIENT_ID="your-kick-client-id"

# Kick OAuth Client Secret
# Get these from: https://kick.com/developer/applications
KICK_CLIENT_SECRET="your-kick-client-secret"

# Kick OAuth Redirect URI
# For local development, use this:
KICK_REDIRECT_URI="http://localhost:3001/api/auth/kick/callback"
# For production, change to:
# KICK_REDIRECT_URI="https://your-backend-domain.com/api/auth/kick/callback"
# IMPORTANT: Must also add this URL in Kick Developer Portal

# Encryption Salt for OAuth tokens (GENERATE NEW!)
# How to generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_SALT="your-encryption-salt-change-this-in-production"

# Encryption Key for OAuth tokens (GENERATE NEW!)
# How to generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_KEY="your-encryption-key-change-this-in-production"

# Encryption IV for OAuth tokens (GENERATE NEW!)
# How to generate: node -e "console.log(require('crypto').randomBytes(16).toString('base64'))"
ENCRYPTION_IV="your-encryption-iv-change-this-in-production"

# ============================================
# DATABASE CONFIGURATION (REQUIRED)
# ============================================

# PostgreSQL Connection String
# Format: postgresql://username:password@host:port/database

# Local Development (using Docker):
DATABASE_URL="postgresql://postgres:password@localhost:5432/streaming_backend"

# Production (AWS RDS, Render, etc.):
# DATABASE_URL="postgresql://username:password@your-db-host:5432/database_name"

# ============================================
# REDIS CONFIGURATION (OPTIONAL)
# ============================================

# Redis Connection String
# Used for: Caching, leaderboard, session storage

# Local Development (using Docker):
REDIS_URL="redis://localhost:6379"

# Production (AWS ElastiCache, Upstash, etc.):
# REDIS_URL="redis://your-redis-host:6379"

# Skip Redis: Comment out or remove REDIS_URL to disable Redis features

# ============================================
# JWT & SECURITY (REQUIRED - GENERATE NEW!)
# ============================================

# IMPORTANT: Generate new secrets for production!
# How to generate: Run this command 3 times:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"

# JWT Secret (for access tokens)
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"

# JWT Refresh Secret (for refresh tokens)
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"

# JWT Token Expiration Times
JWT_EXPIRES_IN="1h"
JWT_REFRESH_EXPIRES_IN="7d"

# Session Secret (for session encryption)
SESSION_SECRET="your-session-secret-change-this-in-production"

# Bcrypt Rounds (higher = more secure but slower)
BCRYPT_ROUNDS=12

# ============================================
# SERVER CONFIGURATION
# ============================================

# Port for backend server
PORT=3001

# Environment (development or production)
NODE_ENV="development"

# Frontend URL (for CORS)
# Local Development:
CORS_ORIGIN="http://localhost:3000"
# Production:
# CORS_ORIGIN="https://your-frontend-domain.com"

# ============================================
# RATE LIMITING
# ============================================

# Rate limit window in milliseconds (900000 = 15 minutes)
RATE_LIMIT_WINDOW_MS=900000

# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# POINTS SYSTEM CONFIGURATION
# ============================================

# Points awarded per minute of viewing
POINTS_PER_MINUTE_VIEWING=1

# Bonus points multiplier for special events
BONUS_POINTS_MULTIPLIER=1.5

# ============================================
# LOGGING
# ============================================

# Log level (error, warn, info, debug)
LOG_LEVEL="info"

# Log file location
LOG_FILE="logs/app.log"

# ============================================
# EXTERNAL SERVICES (OPTIONAL)
# ============================================

# Webhook Secret (for external integrations)
WEBHOOK_SECRET="your-webhook-secret"

# Discord Bot Token (Optional - for future bot features)
# Where: Discord Developer Portal → Your App → Bot → Token
# DISCORD_BOT_TOKEN="your-discord-bot-token"

# ============================================
# NOTES
# ============================================

# 1. NEVER commit this file to Git (it's in .gitignore)
# 2. Generate new secrets for production (don't use examples)
# 3. Keep Discord Client Secret and Bot Token private
# 4. Update redirect URIs when deploying to production
# 5. Test locally before deploying
# 6. Backup this file securely

# ============================================
# QUICK SETUP CHECKLIST
# ============================================

# [ ] Created Discord Application
# [ ] Got Discord Client ID and Secret
# [ ] Got Discord Server ID
# [ ] Created Discord invite link
# [ ] Got Admin Discord User ID
# [ ] Got Kick channel username
# [ ] Generated new JWT secrets
# [ ] Generated new session secret
# [ ] Set up PostgreSQL database
# [ ] Updated DATABASE_URL
# [ ] Tested locally
# [ ] Ready to deploy!
