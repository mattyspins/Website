generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                @id @default(uuid())
  discordId              String                @unique @map("discord_id")
  kickUsername           String?               @unique @map("kick_username")
  kickVerified           Boolean               @default(false) @map("kick_verified")
  displayName            String                @map("display_name")
  avatarUrl              String?               @map("avatar_url")
  points                 Int                   @default(0)
  totalEarned            Int                   @default(0) @map("total_earned")
  totalSpent             Int                   @default(0) @map("total_spent")
  isAdmin                Boolean               @default(false) @map("is_admin")
  isSuspended            Boolean               @default(false) @map("is_suspended")
  suspensionReason       String?               @map("suspension_reason")
  suspensionExpiresAt    DateTime?             @map("suspension_expires_at")
  createdAt              DateTime              @default(now()) @map("created_at")
  updatedAt              DateTime              @updatedAt @map("updated_at")
  lastActiveAt           DateTime              @default(now()) @map("last_active_at")
  kickId                 String?               @unique @map("kick_id")
  kickAccessToken        String?               @map("kick_access_token")
  kickRefreshToken       String?               @map("kick_refresh_token")
  kickTokenExpiresAt     DateTime?             @map("kick_token_expires_at")
  isModerator            Boolean               @default(false) @map("is_moderator")
  rainbetUsername        String?               @unique @map("rainbet_username")
  rainbetVerified        Boolean               @default(false) @map("rainbet_verified")
  isVip                  Boolean               @default(false) @map("is_vip")
  isDepositor            Boolean               @default(false) @map("is_depositor")
  totalWagered           Decimal               @default(0) @map("total_wagered") @db.Decimal(15, 2)
  weeklyWagered          Decimal               @default(0) @map("weekly_wagered") @db.Decimal(14, 2)
  monthlyWagered         Decimal               @default(0) @map("monthly_wagered") @db.Decimal(14, 2)
  totalDeposited         Decimal               @default(0) @map("total_deposited") @db.Decimal(15, 2)
  lastDailyCheckIn       DateTime?             @map("last_daily_check_in")
  auditLogsAsAdmin       AuditLog[]            @relation("AdminAuditLogs")
  auditLogsAsTarget      AuditLog[]            @relation("TargetAuditLogs")
  bonusHuntPredictions   BonusHuntPrediction[]
  bonusHuntSessions      BonusHuntSession[]
  leaderboardEntries     LeaderboardEntry[]
  leaderboardWagers      LeaderboardWager[]
  createdLeaderboards    Leaderboard[]
  notifications          Notification[]
  adminPointTransactions PointTransaction[]    @relation("AdminPointTransactions")
  pointTransactions      PointTransaction[]    @relation("UserPointTransactions")
  raffleTickets          RaffleTicket[]
  raffleWins             RaffleWinner[]
  createdRaffles         Raffle[]
  storePurchases         StorePurchase[]
  updatedSystemConfig    SystemConfig[]
  sessions               UserSession[]
  statistics             UserStatistics?
  viewingSessions        ViewingSession[]
  createdGames           GuessTheBalance[]     @relation("GuessTheBalanceCreator")
  wonGames               GuessTheBalance[]     @relation("GuessTheBalanceWinner")
  guessSubmissions       GuessSubmission[]
  milestoneClaims        MilestoneClaim[]
  createdTournaments     Tournament[]          @relation("TournamentCreator")
  tournamentParticipations TournamentParticipant[] @relation("TournamentParticipants")
  tournamentEntries      TournamentEntry[]     @relation("TournamentEntries")
  createdBingos          BonusBingo[]          @relation("BingoCreator")
  currentBingoGames      BonusBingo[]          @relation("BingoCurrentUser")
  bingoParticipations    BingoParticipant[]    @relation("BingoParticipants")
  bingoClaimedCells      BingoCell[]           @relation("BingoCellClaimer")
  viewerPickerWins       ViewerPicker[]        @relation("ViewerPickerWinner")
  viewerPickerEntries    ViewerPickerEntry[]
  slotRequests           SlotRequest[]
  kothEntries            KingOfTheHillEntry[]
  kothRounds             KingOfTheHillRound[]
  razedDailyWagers       RazedDailyWager[]
  monthlyPayouts         MonthlyLeaderboardPayout[]

  @@index([kickId], map: "idx_users_kick_id")
  @@index([kickUsername], map: "idx_users_kick_username")
  @@map("users")
}

model UserSession {
  id               String   @id @default(uuid())
  userId           String   @map("user_id")
  tokenHash        String   @map("token_hash")
  refreshTokenHash String?  @map("refresh_token_hash")
  expiresAt        DateTime @map("expires_at")
  createdAt        DateTime @default(now()) @map("created_at")
  lastUsedAt       DateTime @default(now()) @map("last_used_at")
  userAgent        String?  @map("user_agent")
  ipAddress        String?  @map("ip_address")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_sessions")
}

model PointTransaction {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  amount          Int
  transactionType String   @map("transaction_type")
  reason          String
  referenceId     String?  @map("reference_id")
  referenceType   String?  @map("reference_type")
  adminId         String?  @map("admin_id")
  createdAt       DateTime @default(now()) @map("created_at")
  metadata        Json?
  admin           User?    @relation("AdminPointTransactions", fields: [adminId], references: [id])
  user            User     @relation("UserPointTransactions", fields: [userId], references: [id], onDelete: Cascade)

  @@map("point_transactions")
}

model UserStatistics {
  userId             String    @id @map("user_id")
  totalViewingTime   Int       @default(0) @map("total_viewing_time")
  totalPurchases     Int       @default(0) @map("total_purchases")
  totalRaffleTickets Int       @default(0) @map("total_raffle_tickets")
  totalWins          Int       @default(0) @map("total_wins")
  longestStreak      Int       @default(0) @map("longest_streak")
  currentStreak      Int       @default(0) @map("current_streak")
  lastStreamWatched  DateTime? @map("last_stream_watched")
  achievements       Json      @default("[]")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_statistics")
}

model Leaderboard {
  id          String             @id @default(uuid())
  title       String
  description String?
  prizePool   String             @map("prize_pool")
  status      String             @default("active")
  startDate   DateTime           @map("start_date")
  endDate     DateTime           @map("end_date")
  createdBy   String?            @map("created_by")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  metadata    Json?
  prizes      LeaderboardPrize[]
  wagers      LeaderboardWager[]
  creator     User?              @relation(fields: [createdBy], references: [id])

  @@index([status, startDate, endDate], map: "idx_leaderboards_status_dates")
  @@map("leaderboards")
}

model LeaderboardPrize {
  id               String      @id @default(uuid())
  leaderboardId    String      @map("leaderboard_id")
  position         Int
  prizeAmount      String      @map("prize_amount")
  prizeDescription String?     @map("prize_description")
  createdAt        DateTime    @default(now()) @map("created_at")
  leaderboard      Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)

  @@unique([leaderboardId, position])
  @@map("leaderboard_prizes")
}

model LeaderboardWager {
  id               String      @id @default(uuid())
  leaderboardId    String      @map("leaderboard_id")
  userId           String?     @map("user_id")
  externalUsername String?     @map("external_username")
  wagerAmount      Decimal     @map("wager_amount") @db.Decimal(12, 2)
  submittedAt      DateTime    @default(now()) @map("submitted_at")
  verifiedBy       String?     @map("verified_by")
  verifiedAt       DateTime?   @map("verified_at")
  notes            String?
  leaderboard      Leaderboard @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)
  user             User?       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([leaderboardId, userId], map: "idx_leaderboard_wagers_leaderboard_user")
  @@map("leaderboard_wagers")
}

model LeaderboardEntry {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  periodType  String   @map("period_type")
  periodStart DateTime @map("period_start")
  scoreType   String   @map("score_type")
  score       Int
  rank        Int?
  manualRank  Int?     @map("manual_rank")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodType, periodStart, scoreType])
  @@map("leaderboard_entries")
}

model Raffle {
  id                String         @id @default(uuid())
  title             String
  description       String?
  prize             String
  ticketPrice       Int            @map("ticket_price")
  maxTickets        Int            @map("max_tickets")
  ticketsSold       Int            @default(0) @map("tickets_sold")
  status            String         @default("active")
  category          String?
  isFeatured        Boolean        @default(false) @map("is_featured")
  createdBy         String?        @map("created_by")
  createdAt         DateTime       @default(now()) @map("created_at")
  endsAt            DateTime       @map("ends_at")
  winnerSelectedAt  DateTime?      @map("winner_selected_at")
  metadata          Json?
  maxEntriesPerUser Int            @default(-1) @map("max_entries_per_user")
  numberOfWinners   Int            @default(1) @map("number_of_winners")
  tickets           RaffleTicket[]
  winners           RaffleWinner[]
  creator           User?          @relation(fields: [createdBy], references: [id])

  @@map("raffles")
}

model RaffleTicket {
  id           String        @id @default(uuid())
  raffleId     String        @map("raffle_id")
  userId       String        @map("user_id")
  ticketNumber Int           @map("ticket_number")
  purchasedAt  DateTime      @default(now()) @map("purchased_at")
  raffle       Raffle        @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  winner       RaffleWinner?

  @@unique([raffleId, ticketNumber])
  @@map("raffle_tickets")
}

model RaffleWinner {
  id               String        @id @default(uuid())
  raffleId         String        @map("raffle_id")
  userId           String        @map("user_id")
  ticketId         String?       @unique @map("ticket_id")
  position         Int
  prizeDescription String?       @map("prize_description")
  selectedAt       DateTime      @default(now()) @map("selected_at")
  notifiedAt       DateTime?     @map("notified_at")
  prizeDeliveredAt DateTime?     @map("prize_delivered_at")
  deliveryMethod   String?       @map("delivery_method")
  raffle           Raffle        @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  ticket           RaffleTicket? @relation(fields: [ticketId], references: [id])
  user             User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("raffle_winners")
}

model StoreItem {
  id           String          @id @default(uuid())
  name         String
  description  String?
  price        Int
  category     String
  stock        Int             @default(-1)
  deliveryType String          @default("instant") @map("delivery_type")
  isActive     Boolean         @default(true) @map("is_active")
  sortOrder    Int             @default(0) @map("sort_order")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  metadata     Json?
  purchases    StorePurchase[]

  @@map("store_items")
}

model StorePurchase {
  id           String    @id @default(uuid())
  userId       String    @map("user_id")
  itemId       String    @map("item_id")
  quantity     Int
  unitPrice    Int       @map("unit_price")
  totalPrice   Int       @map("total_price")
  status       String    @default("completed")
  purchasedAt  DateTime  @default(now()) @map("purchased_at")
  deliveredAt  DateTime? @map("delivered_at")
  refundedAt   DateTime? @map("refunded_at")
  refundReason String?   @map("refund_reason")
  metadata     Json?
  item         StoreItem @relation(fields: [itemId], references: [id])
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("store_purchases")
}

model BonusHuntSession {
  id              String                @id @default(uuid())
  userId          String                @map("user_id")
  sessionName     String?               @map("session_name")
  startingBalance Decimal               @map("starting_balance") @db.Decimal(10, 2)
  currentBalance  Decimal               @map("current_balance") @db.Decimal(10, 2)
  targetBalance   Decimal?              @map("target_balance") @db.Decimal(10, 2)
  status          String                @default("active")
  startedAt       DateTime              @default(now()) @map("started_at")
  endedAt         DateTime?             @map("ended_at")
  totalBonuses    Int                   @default(0) @map("total_bonuses")
  totalSpent      Decimal               @default(0) @map("total_spent") @db.Decimal(10, 2)
  totalWon        Decimal               @default(0) @map("total_won") @db.Decimal(10, 2)
  bonusBuys       BonusBuy[]
  predictions     BonusHuntPrediction[]
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bonus_hunt_sessions")
}

model BonusBuy {
  id          String           @id @default(uuid())
  sessionId   String           @map("session_id")
  gameName    String           @map("game_name")
  buyAmount   Decimal          @map("buy_amount") @db.Decimal(10, 2)
  payout      Decimal          @db.Decimal(10, 2)
  multiplier  Decimal          @db.Decimal(6, 2)
  purchasedAt DateTime         @default(now()) @map("purchased_at")
  metadata    Json?
  session     BonusHuntSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("bonus_buys")
}

model BonusHuntPrediction {
  id               String           @id @default(uuid())
  sessionId        String           @map("session_id")
  userId           String           @map("user_id")
  predictedBalance Decimal          @map("predicted_balance") @db.Decimal(10, 2)
  pointsWagered    Int              @map("points_wagered")
  createdAt        DateTime         @default(now()) @map("created_at")
  resolvedAt       DateTime?        @map("resolved_at")
  won              Boolean?
  pointsWon        Int              @default(0) @map("points_won")
  session          BonusHuntSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@map("bonus_hunt_predictions")
}

model ViewingSession {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  streamId        String?   @map("stream_id")
  startedAt       DateTime  @default(now()) @map("started_at")
  endedAt         DateTime? @map("ended_at")
  durationMinutes Int?      @map("duration_minutes")
  pointsEarned    Int       @default(0) @map("points_earned")
  validated       Boolean   @default(false)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("viewing_sessions")
}

model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String
  title     String
  message   String
  channels  String[]
  priority  String    @default("normal")
  readAt    DateTime? @map("read_at")
  createdAt DateTime  @default(now()) @map("created_at")
  expiresAt DateTime? @map("expires_at")
  metadata  Json?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model SystemConfig {
  key         String   @id
  value       Json
  description String?
  updatedBy   String?  @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")
  updater     User?    @relation(fields: [updatedBy], references: [id])

  @@map("system_config")
}

model AuditLog {
  id         String   @id @default(uuid())
  adminId    String?  @map("admin_id")
  action     String
  targetType String?  @map("target_type")
  targetId   String?  @map("target_id")
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  reason     String?
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  admin      User?    @relation("AdminAuditLogs", fields: [adminId], references: [id])
  target     User?    @relation("TargetAuditLogs", fields: [targetId], references: [id])

  @@map("audit_logs")
}


model GuessTheBalance {
  id                   String                    @id @default(uuid())
  title                String?
  description          String?
  startingBalance      Decimal                   @map("starting_balance") @db.Decimal(12, 2)
  numberOfBonuses      Int                       @map("number_of_bonuses")
  breakEvenMultiplier  Decimal                   @map("break_even_multiplier") @db.Decimal(6, 2)
  finalBalance         Decimal?                  @map("final_balance") @db.Decimal(12, 2)
  status               GuessTheBalanceStatus     @default(DRAFT)
  winnerId             String?                   @map("winner_id")
  winnerGuess          Decimal?                  @map("winner_guess") @db.Decimal(12, 2)
  winnerReward         Int?                      @default(0) @map("winner_reward")
  createdBy            String                    @map("created_by")
  createdAt            DateTime                  @default(now()) @map("created_at")
  openedAt             DateTime?                 @map("opened_at")
  closedAt             DateTime?                 @map("closed_at")
  completedAt          DateTime?                 @map("completed_at")
  metadata             Json?
  creator              User                      @relation("GuessTheBalanceCreator", fields: [createdBy], references: [id])
  winner               User?                     @relation("GuessTheBalanceWinner", fields: [winnerId], references: [id])
  guesses              GuessSubmission[]

  @@index([status])
  @@index([createdBy])
  @@map("guess_the_balance")
}

model GuessSubmission {
  id           String          @id @default(uuid())
  gameId       String          @map("game_id")
  userId       String          @map("user_id")
  guessAmount  Decimal         @map("guess_amount") @db.Decimal(12, 2)
  submittedAt  DateTime        @default(now()) @map("submitted_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")
  game         GuessTheBalance @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@index([gameId])
  @@index([userId])
  @@map("guess_submissions")
}

enum GuessTheBalanceStatus {
  DRAFT
  OPEN
  CLOSED
  COMPLETED
}

enum TournamentStatus {
  DRAFT
  REGISTRATION
  SLOT_SELECTION
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MatchStatus {
  PENDING
  SLOT_SELECTION
  ACTIVE
  COMPLETED
}

model Tournament {
  id               String                  @id @default(uuid())
  title            String
  status           TournamentStatus        @default(DRAFT)
  maxPlayers       Int                     @default(8) @map("max_players")
  slotTimerSeconds Int                     @default(180) @map("slot_timer_seconds")
  currentRound     Int                     @default(0) @map("current_round")
  createdById      String                  @map("created_by_id")
  createdAt        DateTime                @default(now()) @map("created_at")
  updatedAt        DateTime                @updatedAt @map("updated_at")
  createdBy        User                    @relation("TournamentCreator", fields: [createdById], references: [id])
  participants     TournamentParticipant[]
  matches          TournamentMatch[]
  entries          TournamentEntry[]

  @@map("tournaments")
}

model TournamentParticipant {
  id                  String                       @id @default(uuid())
  tournamentId        String                       @map("tournament_id")
  userId              String                       @map("user_id")
  seed                Int?
  currentSlot         String?                      @map("current_slot")
  slotConfirmed       Boolean                      @default(false) @map("slot_confirmed")
  slotDeadline        DateTime?                    @map("slot_deadline")
  eliminated          Boolean                      @default(false)
  finalPosition       Int?                         @map("final_position")
  createdAt           DateTime                     @default(now()) @map("created_at")
  tournament          Tournament                   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user                User                         @relation("TournamentParticipants", fields: [userId], references: [id], onDelete: Cascade)
  matchParticipations TournamentMatchParticipant[]

  @@unique([tournamentId, userId])
  @@map("tournament_participants")
}

model TournamentEntry {
  id           String     @id @default(uuid())
  tournamentId String     @map("tournament_id")
  userId       String     @map("user_id")
  enteredAt    DateTime   @default(now()) @map("entered_at")
  tournament   Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user         User       @relation("TournamentEntries", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@map("tournament_entries")
}

model TournamentMatch {
  id           String                       @id @default(uuid())
  tournamentId String                       @map("tournament_id")
  round        Int
  matchNumber  Int                          @map("match_number")
  status       MatchStatus                  @default(PENDING)
  winnerId     String?                      @map("winner_id")
  nextMatchId  String?                      @map("next_match_id")
  slotDeadline DateTime?                    @map("slot_deadline")
  createdAt    DateTime                     @default(now()) @map("created_at")
  updatedAt    DateTime                     @updatedAt @map("updated_at")
  tournament   Tournament                   @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  participants TournamentMatchParticipant[]

  @@unique([tournamentId, round, matchNumber])
  @@map("tournament_matches")
}

model TournamentMatchParticipant {
  id              String                @id @default(uuid())
  matchId         String                @map("match_id")
  participantId   String                @map("participant_id")
  slotCall        String?               @map("slot_call")
  slotConfirmed   Boolean               @default(false) @map("slot_confirmed")
  slotConfirmedAt DateTime?             @map("slot_confirmed_at")
  match           TournamentMatch       @relation(fields: [matchId], references: [id], onDelete: Cascade)
  participant     TournamentParticipant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([matchId, participantId])
  @@map("tournament_match_participants")
}

model StreamEvent {
  id          String   @id @default(uuid())
  title       String
  scheduledAt DateTime @map("scheduled_at")
  gameType    String?  @map("game_type")
  description String?
  isLive      Boolean  @default(false) @map("is_live")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([scheduledAt])
  @@map("stream_events")
}

model MilestoneClaim {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  tierId    Int      @map("tier_id")
  tierName  String   @map("tier_name")
  reward    Int
  status    String   @default("pending")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tierId])
  @@map("milestone_claims")
}

// ─── Viewer Picker ────────────────────────────────────────────────────────────

enum ViewerPickerStatus {
  OPEN
  CLOSED
  COMPLETED
}

model ViewerPicker {
  id        String              @id @default(uuid())
  keyword   String
  label     String?
  status    ViewerPickerStatus  @default(OPEN)
  winnerId  String?             @map("winner_id")
  createdAt DateTime            @default(now()) @map("created_at")
  closedAt  DateTime?           @map("closed_at")
  entries   ViewerPickerEntry[]
  winner    User?               @relation("ViewerPickerWinner", fields: [winnerId], references: [id])

  @@map("viewer_pickers")
}

model ViewerPickerEntry {
  id        String       @id @default(uuid())
  pickerId  String       @map("picker_id")
  userId    String       @map("user_id")
  enteredAt DateTime     @default(now()) @map("entered_at")
  picker    ViewerPicker @relation(fields: [pickerId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pickerId, userId])
  @@map("viewer_picker_entries")
}

// ─── King of the Hill ─────────────────────────────────────────────────────────

enum KingOfTheHillStatus {
  OPEN
  CLOSED
}

enum KothEntryStatus {
  WAITING
  DRAWN
  KING
}

model KingOfTheHill {
  id        String              @id @default(uuid())
  label     String?
  status    KingOfTheHillStatus @default(OPEN)
  createdAt DateTime            @default(now()) @map("created_at")
  closedAt  DateTime?           @map("closed_at")
  entries   KingOfTheHillEntry[]
  rounds    KingOfTheHillRound[]

  @@map("king_of_the_hill_sessions")
}

model KingOfTheHillEntry {
  id        String            @id @default(uuid())
  sessionId String            @map("session_id")
  userId    String            @map("user_id")
  status    KothEntryStatus   @default(WAITING)
  joinedAt  DateTime          @default(now()) @map("joined_at")
  drawnAt   DateTime?         @map("drawn_at")
  session   KingOfTheHill        @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  rounds    KingOfTheHillRound[]

  @@unique([sessionId, userId])
  @@map("king_of_the_hill_entries")
}

model KingOfTheHillRound {
  id           String    @id @default(uuid())
  sessionId    String    @map("session_id")
  entryId      String    @map("entry_id")
  userId       String    @map("user_id")
  slotName     String?   @map("slot_name")
  betAmount    Decimal?  @map("bet_amount") @db.Decimal(10, 2)
  payoutAmount Decimal?  @map("payout_amount") @db.Decimal(10, 2)
  multiplier   Decimal?  @db.Decimal(6, 2)
  isKing       Boolean   @default(false) @map("is_king")
  drawnAt      DateTime  @default(now()) @map("drawn_at")
  slotCalledAt DateTime? @map("slot_called_at")
  playedAt     DateTime? @map("played_at")
  dethronedAt  DateTime? @map("dethroned_at")
  session      KingOfTheHill      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  entry        KingOfTheHillEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("king_of_the_hill_rounds")
}

// ─── Bonus Bingo ─────────────────────────────────────────────────────────────

enum BingoStatus {
  DRAFT
  REGISTRATION
  ACTIVE
  COMPLETED
  CANCELLED
}

enum CellStatus {
  EMPTY
  ACTIVE
  GREEN
  RED
}

model BonusBingo {
  id            String             @id @default(uuid())
  title         String
  gridSize      Int                @default(5) @map("grid_size")
  status        BingoStatus        @default(DRAFT)
  linePoints    Int                @default(500) @map("line_points")
  currentCellId String?            @map("current_cell_id")
  currentUserId String?            @map("current_user_id")
  createdById   String             @map("created_by_id")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  completedAt   DateTime?          @map("completed_at")
  createdBy     User               @relation("BingoCreator", fields: [createdById], references: [id])
  currentUser   User?              @relation("BingoCurrentUser", fields: [currentUserId], references: [id])
  cells         BingoCell[]
  participants  BingoParticipant[]
  lineWins      BingoLineWin[]

  @@map("bonus_bingo")
}

model BingoCell {
  id          String     @id @default(uuid())
  gameId      String     @map("game_id")
  row         Int
  col         Int
  status      CellStatus @default(EMPTY)
  slotName    String?    @map("slot_name")
  claimedById String?    @map("claimed_by_id")
  claimedAt   DateTime?  @map("claimed_at")
  playedAt    DateTime?  @map("played_at")
  game        BonusBingo @relation(fields: [gameId], references: [id], onDelete: Cascade)
  claimedBy   User?      @relation("BingoCellClaimer", fields: [claimedById], references: [id])

  @@unique([gameId, row, col])
  @@map("bingo_cells")
}

model BingoParticipant {
  id       String     @id @default(uuid())
  gameId   String     @map("game_id")
  userId   String     @map("user_id")
  joinedAt DateTime   @default(now()) @map("joined_at")
  game     BonusBingo @relation(fields: [gameId], references: [id], onDelete: Cascade)
  user     User       @relation("BingoParticipants", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([gameId, userId])
  @@map("bingo_participants")
}

// ─── Slot Requests ───────────────────────────────────────────────────────────

enum SlotRequestStatus {
  PENDING
  ADDED
  REJECTED
}

model SlotRequest {
  id           String            @id @default(uuid())
  slotName     String            @map("slot_name")
  kickUsername String            @map("kick_username")
  userId       String?           @map("user_id")
  status       SlotRequestStatus @default(PENDING)
  requestedAt  DateTime          @default(now()) @map("requested_at")
  user         User?             @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([status], map: "idx_slot_requests_status")
  @@map("slot_requests")
}

model BingoLineWin {
  id          String     @id @default(uuid())
  gameId      String     @map("game_id")
  lineType    String     @map("line_type")
  lineIndex   Int        @map("line_index")
  pointsEach  Int        @map("points_each")
  completedAt DateTime   @default(now()) @map("completed_at")
  game        BonusBingo @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([gameId, lineType, lineIndex])
  @@map("bingo_line_wins")
}

// ─── Razed Wager Tracking ───────────────────────────────────────────────────

model RazedDailyWager {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  date      DateTime @db.Date
  amount    Decimal  @db.Decimal(14, 2)
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("razed_daily_wagers")
}

model RazedUnlinkedWager {
  id            String   @id @default(uuid())
  razedUsername String   @map("razed_username")
  date          DateTime @db.Date
  amount        Decimal  @db.Decimal(14, 2)
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([razedUsername, date])
  @@index([razedUsername])
  @@map("razed_unlinked_wagers")
}

model MonthlyLeaderboardPrize {
  id       String @id @default(uuid())
  position Int    @unique
  points   Int

  @@map("monthly_leaderboard_prizes")
}

model MonthlyLeaderboardPayout {
  id            String   @id @default(uuid())
  monthStart    DateTime @map("month_start") @db.Date
  userId        String   @map("user_id")
  position      Int
  wagered       Decimal  @db.Decimal(14, 2)
  pointsAwarded Int      @map("points_awarded")
  paidAt        DateTime @default(now()) @map("paid_at")
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([monthStart, userId])
  @@map("monthly_leaderboard_payouts")
}
