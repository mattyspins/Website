# Production Environment Configuration
# Copy this file to .env.production and fill in your actual values

# Application
NODE_ENV=production
PORT=3001

# Database Configuration
# Replace with your AWS RDS PostgreSQL connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@your-rds-endpoint.region.rds.amazonaws.com:5432/postgres

# Redis Configuration
# Option 1: AWS ElastiCache
# REDIS_URL=redis://your-elasticache-endpoint:6379
# Option 2: Redis Cloud (recommended)
REDIS_URL=redis://username:password@your-redis-host:port

# Security Configuration
# Generate a secure JWT secret (minimum 32 characters)
JWT_SECRET=your-super-secure-jwt-secret-minimum-32-characters-long
# Generate a 32-character encryption key
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Discord OAuth Configuration
# Get these from https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=https://yourdomain.com/auth/callback

# CORS Configuration
# Set to your frontend domain
CORS_ORIGIN=https://yourdomain.com

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging Configuration
LOG_LEVEL=info

# Optional: Sentry for error tracking
# SENTRY_DSN=your-sentry-dsn-here

# Optional: AWS Configuration (if using AWS services)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key