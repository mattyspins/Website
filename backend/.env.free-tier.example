# Free Tier Production Environment Configuration
# Optimized for AWS Free Tier (t2.micro + db.t2.micro)

# Application
NODE_ENV=production
PORT=3001

# Database Configuration (AWS RDS Free Tier)
# db.t2.micro instance with minimal configuration
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@your-free-tier-rds.region.rds.amazonaws.com:5432/postgres

# Redis Configuration (FREE OPTIONS)
# Option 1: Redis Cloud Free Tier (30MB) - RECOMMENDED
REDIS_URL=redis://default:your-password@your-redis-cloud-host:port
# Option 2: Local Redis on EC2 (uses your free EC2 resources)
# REDIS_URL=redis://localhost:6379

# Security Configuration
# Generate secure secrets (use: openssl rand -base64 32)
JWT_SECRET=your-super-secure-jwt-secret-minimum-32-characters-long
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Discord OAuth Configuration
# Get these from https://discord.com/developers/applications
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret
DISCORD_REDIRECT_URI=https://yourdomain.com/auth/callback

# CORS Configuration
# Set to your Vercel frontend domain
CORS_ORIGIN=https://yourdomain.vercel.app

# Rate Limiting (Conservative for Free Tier)
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=50   # Lower limit to protect resources

# Logging Configuration (Minimal for Free Tier)
LOG_LEVEL=warn  # Only log warnings and errors to save disk space

# Free Tier Optimizations
NODE_OPTIONS=--max-old-space-size=512  # Limit memory usage
UV_THREADPOOL_SIZE=2  # Reduce thread pool size

# Database Connection Pool (Optimized for Free Tier)
DATABASE_POOL_MIN=1
DATABASE_POOL_MAX=3  # Low connection pool for db.t2.micro

# Session Configuration (Memory optimized)
SESSION_SECRET=your-session-secret-here
SESSION_MAX_AGE=86400000  # 24 hours

# File Upload Limits (Save bandwidth and storage)
MAX_FILE_SIZE=1048576  # 1MB max file size
MAX_FILES_PER_REQUEST=3

# Cache Configuration (Minimal)
CACHE_TTL=300  # 5 minutes cache TTL
CACHE_MAX_KEYS=100  # Limit cache size

# Monitoring (Disabled to save resources)
ENABLE_METRICS=false
ENABLE_HEALTH_CHECKS=true  # Keep basic health checks only

# Free Tier Specific Settings
AWS_REGION=us-east-1  # Use us-east-1 for better free tier availability
ENABLE_COMPRESSION=true  # Enable gzip to save bandwidth
ENABLE_RATE_LIMITING=true  # Protect against abuse

# Optional: Error Tracking (Free tiers available)
# SENTRY_DSN=your-sentry-dsn-here  # Sentry has a free tier

# Development vs Production toggles
ENABLE_SWAGGER=false  # Disable API docs in production
ENABLE_CORS_CREDENTIALS=true
TRUST_PROXY=true  # Trust Nginx proxy

# Database Query Optimizations
ENABLE_QUERY_LOGGING=false  # Disable to save disk space
SLOW_QUERY_THRESHOLD=1000  # 1 second threshold

# Socket.IO Configuration (Optimized)
SOCKET_IO_TRANSPORTS=websocket,polling
SOCKET_IO_PING_TIMEOUT=20000
SOCKET_IO_PING_INTERVAL=25000

# Backup Configuration (Minimal)
ENABLE_AUTO_BACKUP=false  # Disable to save storage costs
BACKUP_RETENTION_DAYS=3   # Keep minimal backups

# Security Headers (Basic)
ENABLE_HELMET=true
HELMET_CONTENT_SECURITY_POLICY=false  # Disable CSP to reduce complexity

# Performance Settings (Free Tier Optimized)
ENABLE_CLUSTERING=false  # Single process for t2.micro
WORKER_PROCESSES=1
KEEP_ALIVE_TIMEOUT=5000
HEADERS_TIMEOUT=6000

# Free Tier Monitoring URLs
# Use these to monitor your free tier usage:
# AWS Billing: https://console.aws.amazon.com/billing/
# EC2 Usage: https://console.aws.amazon.com/ec2/
# RDS Usage: https://console.aws.amazon.com/rds/