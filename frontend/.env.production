# Production Environment Variables
# Backend URL for production deployment.
#
# Must remain SAME-SITE with the frontend (mattyspins.com). The auth cookies are
# SameSite=lax, which browsers do not attach to cross-site subrequests, so a
# foreign API domain (e.g. *.up.railway.app) leaves every authenticated request
# unauthenticated regardless of CORS. See backend/src/middleware/auth.ts.
NEXT_PUBLIC_API_URL=https://api.mattyspins.com
